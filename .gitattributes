# Normalize all text files to LF on commit (cross-platform consistency)
* text=auto eol=lf

# Explicitly enforce LF for these file types
*.ts        text eol=lf
*.js        text eol=lf
*.feature   text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.zip       binary