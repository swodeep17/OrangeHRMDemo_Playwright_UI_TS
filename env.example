# ═══════════════════════════════════════════════════════════════════════════════
# .env.example  —  place this file at PROJECT ROOT  (same level as package.json)
# ───────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   LOCAL  : cp .env.example .env  → fill real values → never commit .env
#   CI/CD  : GitHub Actions reads from Secrets  (Settings → Secrets → Actions)
#            Jenkins reads from Credentials     (Manage Jenkins → Credentials)
#            Azure DevOps reads from Pipelines  (Pipelines → Library → Variable Groups)
#
# NEVER commit .env — it is git-ignored.
# ALWAYS commit .env.example — it is the team contract for what vars are needed.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment switch ────────────────────────────────────────────────────────
# Controls which BASE_URL is picked in env.config.ts
# Options: dev | staging | prod
ENV=dev

# ── Superadmin credentials ────────────────────────────────────────────────────
SUPERADMIN_USER=Admin
SUPERADMIN_PASS=admin123

# ── Client Admin credentials (filled after @createEmp + @employeeRoleMapping) ─
CLIENTADMIN_USER=
CLIENTADMIN_PASS=

# ── ESS User credentials ──────────────────────────────────────────────────────
ESS_USER=
ESS_PASS=

# ── Azure Key Vault (enterprise — leave blank for local/GitHub) ───────────────
# AZURE_VAULT_URL=https://your-vault-name.vault.azure.net

# ── Health-check safety net ───────────────────────────────────────────────────
# If EXPECTED_ENV_URL is set, global.setup.ts aborts if BASE_URL doesn't match.
# Prevents accidentally running against PROD when pipeline is set to staging.
EXPECTED_ENV_URL=https://opensource-demo.orangehrmlive.com
